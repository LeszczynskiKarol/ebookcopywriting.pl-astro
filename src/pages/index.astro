---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BuyButton from '../components/BuyButton.astro';
import SectionHeading from '../components/SectionHeading.astro';

const API_URL = 'https://452b6mr08j.execute-api.eu-central-1.amazonaws.com/prod';
const PREVIEW_PDF_URL = 'https://www.ebookcopywriting.pl/copywriting-360-preview.pdf';

const ebook = { id: 'ebook-copywriting-360', name: 'Copywriting 360°', subtitle: 'Jak pisać teksty, które sprzedają', price: 49, pages: '208', chapters: 16, format: 'PDF' };

const checklistItems = [
  'Piszesz teksty na stronę firmową, ale nie wiesz, dlaczego nie konwertują',
  'Tworzysz posty w social media, ale nikt ich nie komentuje ani nie udostępnia',
  'Wysyłasz maile sprzedażowe, których open rate nie przekracza 15%',
  'Chcesz zostać copywriterem, ale nie wiesz od czego zacząć',
  'Już piszesz teksty na zlecenie, ale chcesz podnieść swoje stawki',
  'Tworzysz landing page, ale współczynnik konwersji jest żałośnie niski',
  'Nie wiesz, jak pisać nagłówki, które zatrzymują scrollowanie',
  'Nie rozumiesz, czym różni się cecha od korzyści',
  'Nie znasz formuł copywriterskich (AIDA, PAS, 4U, APP)',
  'Używasz ChatGPT do pisania, ale wyniki są generyczne i sztuczne',
  'Chcesz pisać teksty SEO, które rankują I czyta się je z przyjemnością',
  'Piszesz „na czuja" zamiast korzystać ze sprawdzonych procesów',
  'Chcesz zaoszczędzić lata prób i błędów',
];

const forWho = [
  { label: 'Początkujący copywriter', desc: 'chcesz wejść w branżę z solidnymi fundamentami' },
  { label: 'Freelancer', desc: 'piszesz teksty, ale chcesz systematyzować wiedzę i podnieść stawki' },
  { label: 'Właściciel firmy', desc: 'sam piszesz teksty na stronę i social media' },
  { label: 'Marketer', desc: 'tworzysz treści w pracy, ale nikt Cię nie uczył pisać sprzedażowo' },
  { label: 'Student', desc: 'rozważasz karierę w copywritingu' },
];
const notForWho = [
  'Szukasz magicznego przycisku „zarabiaj 10 000 zł"',
  'Myślisz, że AI napisze wszystko za Ciebie',
  'Nie zamierzasz ćwiczyć — sam ebook nie wystarczy',
  'Jesteś doświadczonym copywriterem z 10+ latami praktyki',
  'Szukasz kursu wideo z mentorem i feedbackiem na żywo',
];

const benefits = [
  { icon: '⏰', title: 'Oszczędzasz setki godzin', desc: 'Zamiast zbierać wiedzę z 50 artykułów, 20 filmów i 10 książek — masz wszystko w jednym miejscu.' },
  { icon: '💰', title: 'Zarabiasz więcej', desc: 'Copywriter, który zna formuły i techniki edycji — bierze wyższe stawki. Ebook uczy Cię nie tylko JAK, ale DLACZEGO.' },
  { icon: '🎯', title: 'Teksty zaczynają konwertować', desc: 'Nagłówki, które zatrzymują. Leady, od których nie da się oderwać. CTA, które klikają. Nie magia — system.' },
  { icon: '🧠', title: 'Rozumiesz psychologię', desc: 'Wiesz, DLACZEGO dany nagłówek działa, dlaczego ta kolejność argumentów przekonuje.' },
  { icon: '✂️', title: 'Teksty są dopracowane', desc: 'Znasz trzypoziomowy system edycji. Wiesz, jak skracać, co wycinać, kiedy tekst jest gotowy.' },
  { icon: '🤖', title: 'Nie boisz się AI', desc: 'Wiesz, jak współpracować z AI mądrze i etycznie. Ty kontrolujesz proces i efekt końcowy.' },
];

const faqItems = [
  { q: 'Czy ten ebook jest aktualny?', a: 'Tak — książka jest aktualizowana na 2026 rok. Zawiera rozdział o współpracy z AI (ChatGPT, Claude), aktualny przegląd narzędzi i realne stawki copywriterów na polskim rynku.' },
  { q: 'Dla kogo jest ten ebook?', a: 'Dla każdego, kto pisze lub chce pisać teksty marketingowe i sprzedażowe: początkujących copywriterów, freelancerów, właścicieli firm, marketerów i pracowników agencji.' },
  { q: 'Czym różni się od książek Jabłońskiego czy Puzyrkiewicza?', a: 'Copywriting 360° łączy zagadnienia rozrzucone w innych publikacjach: psychologia + techniki + SEO + edycja + AI + kariera. Wszystko w jednym spójnym systemie z ćwiczeniami.' },
  { q: 'Nie jestem copywriterem — czy książka jest dla mnie?', a: 'Jak najbardziej. Jeśli prowadzisz firmę i sam piszesz teksty na stronę, maile czy social media — ebook pokaże Ci, jak robić to skuteczniej.' },
  { q: 'Jak szybko dostanę ebook po zakupie?', a: 'Natychmiast. Po opłaceniu zamówienia otrzymasz link do pobrania na podany email. Cały proces trwa poniżej minuty.' },
  { q: 'Jakie metody płatności akceptujecie?', a: 'BLIK, karty (Visa, Mastercard), Google Pay, Apple Pay. Płatności obsługuje Stripe — bezpieczny, szyfrowany system.' },
  { q: 'Czy mogę dostać fakturę?', a: 'Tak — napisz na kontakt@ebookcopywriting.pl z danymi do faktury, a wyślemy ją mailem.' },
  { q: 'Czy książka pomoże mi używać AI w copywritingu?', a: 'Tak — cały rozdział poświęcony jest pracy z AI. Poznasz metodę kanapki Human–AI–Human, dowiesz się do czego AI się nadaje i jak unikać generycznego contentu.' },
  { q: 'W internecie jest dużo darmowych poradników. Czym ten się różni?', a: 'Darmowe poradniki pokrywają fragmenty wiedzy i wymagają godzin szukania. Copywriting 360° to kompletny system w jednym miejscu: formuły, przykłady, ćwiczenia z ramami czasowymi, checklisty.' },
  { q: 'Czy ebook nada się na Kindle / czytnik?', a: 'Ebook jest w formacie PDF, zoptymalizowanym pod komputery i tablety. Na czytnikach e-ink da się go czytać, ale najlepszy komfort na urządzeniu z większym ekranem.' },
];
---

<Layout
  title="Ebook Copywriting 360° — książka-poradnik o pisania tekstów, które sprzedają | PDF 2026"
  description="Ebook o copywritingu po polsku. Książka obejmuje 208 stron, 16 rozdziałów, gotowe formuły, ćwiczenia i rozdział o AI. Naucz się pisać teksty sprzedażowe, nagłówki, landing page, e-maile i oferty. 49 zł."
>
<Navbar />
<main class="min-h-screen">

<!-- ============ HERO — deep navy with ebook cover ============ -->
<section class="relative bg-navy-900 text-white pt-24 pb-16 md:pt-32 md:pb-28 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-60"></div>
  <div class="absolute top-[-100px] right-[-50px] w-[500px] h-[500px] rounded-full border border-primary-500/10"></div>
  <div class="absolute top-[-140px] right-[-90px] w-[580px] h-[580px] rounded-full border border-primary-500/5"></div>
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-accent-cyan/5 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-primary-500/5 rounded-full blur-[80px]"></div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <div class="flex flex-wrap gap-2 mb-8">
          <span class="badge bg-primary-500/15 text-primary-300 border border-primary-500/25">📖 Ebook PDF</span>
          <span class="badge bg-white/5 text-slate-300 border border-white/10">208 stron</span>
          <span class="badge bg-white/5 text-slate-300 border border-white/10">16 rozdziałów</span>
          <span class="badge bg-accent-green/15 text-green-300 border border-accent-green/25">🤖 + Rozdział o AI</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4 leading-[1.1] tracking-tight">
          <span class="font-display italic text-primary-400">Copywriting 360°</span><br />
          <span class="text-white">ebook o&nbsp;copywritingu i&nbsp;pisaniu tekstów</span>
        </h1>

        <div class="w-24 h-1 bg-accent-green mb-6 rounded-full"></div>

        <p class="text-xl text-slate-400 font-medium mb-4">Od psychologii do konwersji</p>

        <p class="text-slate-300 text-lg leading-relaxed mb-8 max-w-xl">
          Nie musisz być „urodzonym pisarzem". Potrzebujesz <strong class="text-white">systemu</strong> — sprawdzonych formuł, technik i procesów. Ta książka daje Ci <strong class="text-white">208 stron</strong> praktycznej wiedzy, zgromadzonej przez 15 lat pracy w copywritingu.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
          <div class="bg-white/5 border border-white/10 rounded-xl px-6 py-3">
            <span class="text-4xl font-extrabold text-white">{ebook.price} zł</span>
          </div>
          <BuyButton text="Kupuję teraz" size="lg" />
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-400">
          {['Dostęp w 30 sekund', 'Bezpieczna płatność', 'PDF na każde urządzenie'].map(item => (
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- Ebook cover image -->
      <div class="relative lg:pl-8 flex justify-center">
        <div class="relative transform lg:rotate-2 hover:rotate-0 transition-transform duration-500 group">
          <!-- Glow behind cover -->
          <div class="absolute -inset-8 bg-gradient-to-br from-primary-400/30 to-accent-green/20 rounded-3xl blur-3xl opacity-80 group-hover:opacity-100 transition-opacity"></div>
          <!-- Cover -->
          <img
            src="/cover-1.webp"
            alt="Okładka ebooka Copywriting 360° — Od psychologii do konwersji"
            class="relative w-[300px] md:w-[360px] lg:w-[420px] rounded-2xl shadow-2xl shadow-black/50 border-2 border-white/20 ring-1 ring-white/10 ring-offset-4 ring-offset-navy-900"
            width="420"
            height="594"
            loading="eager"
          />
          <!-- AI badge -->
          <div class="absolute -bottom-4 -right-4 bg-navy-900 border-2 border-accent-green rounded-xl px-5 py-2.5 shadow-xl">
            <span class="text-sm font-bold text-accent-green flex items-center gap-2">🤖 Z rozdziałem o AI</span>
          </div>
          <!-- Price tag -->
          <div class="absolute -top-3 -left-3 bg-primary-600 text-white rounded-xl px-4 py-2 shadow-xl">
            <span class="text-lg font-extrabold">49 zł</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ TRUST BAR ============ -->
<section class="bg-primary-500 py-4">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-white text-sm font-medium">
      <span>✓ 208 stron praktycznej wiedzy</span>
      <span>✓ Gotowe formuły i szablony</span>
      <span>✓ Aktualizowany na 2026</span>
      <span>✓ Rozdział o AI w copywritingu</span>
    </div>
  </div>
</section>

<!-- ============ PROBLEM ============ -->
<section class="py-20 md:py-28 px-4 bg-white">
  <div class="container-narrow text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8">
      Pisanie tekstów sprzedażowych to <span class="font-display italic text-primary-700">umiejętność</span>, nie talent
    </h2>
    <p class="text-lg text-slate-600 leading-relaxed max-w-3xl mx-auto mb-8">
      Większość tekstów na polskich stronach popełnia te same błędy: mówi o firmie zamiast o kliencie, używa pustych frazesów typu „innowacyjne rozwiązania", a zamiast CTA — kończy się ogólnikiem „skontaktuj się z nami".
    </p>
    <p class="text-lg text-slate-700 font-medium mb-8">Efekt? Strony, które nie konwertują. Maile, których nikt nie otwiera. Oferty w koszu.</p>
    <p class="text-lg text-slate-600">
      <strong class="text-slate-900">Nie musisz tak mieć.</strong> Copywriting to rzemiosło — zestaw powtarzalnych technik i formuł, których można się nauczyć.
    </p>
  </div>
</section>

<!-- ============ CHECKLIST ============ -->
<section id="dla-kogo" class="py-20 md:py-28 px-4 bg-slate-50">
  <div class="max-w-5xl mx-auto">
    <SectionHeading title="Ta książka o copywritingu jest dla Ciebie, jeśli:" subtitle="Zaznacz w głowie, ile z tych punktów Cię dotyczy 👇" />
    <div class="grid md:grid-cols-2 gap-3">
      {checklistItems.map((item, i) => (
        <label class="reveal bg-white p-4 rounded-xl border border-slate-200 flex items-start gap-3 cursor-pointer hover:border-primary-400 hover:shadow-sm transition-all group" style={`animation-delay:${i*0.03}s`}>
          <input type="checkbox" class="mt-1 w-5 h-5 rounded border-slate-300 text-primary-500 focus:ring-primary-400 shrink-0" />
          <span class="text-slate-700 group-hover:text-slate-900 transition-colors">{item}</span>
        </label>
      ))}
    </div>
    <div class="text-center mt-12">
      <p class="text-xl text-slate-800 font-bold mb-2">Jeśli zaznaczyłeś chociaż <span class="text-primary-600">3 punkty</span> — ten ebook rozwiąże Twoje problemy.</p>
      <p class="text-slate-600">Wszystkie kwestie są szczegółowo omówione na 208 stronach.</p>
    </div>
  </div>
</section>

<!-- ============ TAK / NIE ============ -->
<section class="py-20 md:py-28 px-4 bg-white border-t border-slate-100">
  <div class="max-w-5xl mx-auto">
    <SectionHeading title="Czy Copywriting 360° jest dla Ciebie?" />
    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-emerald-50 border-2 border-emerald-200 rounded-2xl p-8">
        <h3 class="text-xl font-bold text-emerald-800 mb-6 flex items-center gap-2"><span class="text-2xl">✅</span> Ten ebook JEST dla Ciebie:</h3>
        <ul class="space-y-4">
          {forWho.map(item => (
            <li class="flex items-start gap-3"><span class="text-emerald-600 font-bold text-lg mt-0.5">+</span><span class="text-slate-700"><strong class="text-slate-900">{item.label}</strong> — {item.desc}</span></li>
          ))}
        </ul>
      </div>
      <div class="bg-red-50 border-2 border-red-200 rounded-2xl p-8">
        <h3 class="text-xl font-bold text-red-800 mb-6 flex items-center gap-2"><span class="text-2xl">❌</span> Ta książka NIE jest dla Ciebie:</h3>
        <ul class="space-y-4">
          {notForWho.map(item => (
            <li class="flex items-start gap-3"><span class="text-red-500 font-bold text-lg mt-0.5">−</span><span class="text-slate-700">{item}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ============ COMPARISON TABLE ============ -->
<section class="bg-navy-900 text-white relative overflow-hidden py-20 md:py-28 px-4">
  <div class="max-w-5xl mx-auto relative z-10">
    <SectionHeading title="Dlaczego akurat TEN ebook o copywritingu?" subtitle="Na rynku jest mnóstwo książek i kursów. Czym Copywriting 360° się różni?" light={true} />
    <div class="overflow-x-auto -mx-4 px-4">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr>
            <th class="text-left p-4 text-slate-400 font-medium"></th>
            <th class="p-4 text-slate-400 font-medium text-center">Darmowe poradniki</th>
            <th class="p-4 text-slate-400 font-medium text-center">Kursy online<br/><span class="text-xs">(300–800 zł)</span></th>
            <th class="p-4 text-center font-bold rounded-t-xl bg-primary-600 text-white border-2 border-primary-500 border-b-0">
              ✅ Copywriting 360°<br/><span class="text-xs font-normal text-primary-100">(49 zł)</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Zakres', 'Fragmentaryczny', 'Często rozwodniony', '16 rozdziałów — kompletny system A–Z'],
            ['Ćwiczenia', 'Brak', 'Bez ram czasowych', 'Z konkretnymi ramami czasowymi'],
            ['Formuły', 'Wymienione z nazwy', 'Anglojęzyczne przykłady', 'Polskie przykłady przed/po'],
            ['AI', 'Brak lub ogólniki', 'Jeden moduł', 'Cały rozdział — Human–AI–Human'],
            ['SEO', 'Osobny artykuł', 'Wspomniany', 'Dedykowany rozdział'],
            ['Edycja tekstu', 'Nigdy', 'Rzadko', '3-poziomowy system + checklist'],
            ['Aktualność', 'Sprzed 3–5 lat', 'Zależy od edycji', 'Aktualizowany na 2026'],
            ['Cena', '0 zł (30h szukania)', '300–800 zł', '49 zł'],
          ].map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-white/[0.02]' : ''}>
              <td class="p-4 font-medium text-white">{row[0]}</td>
              <td class="p-4 text-center text-slate-400">{row[1]}</td>
              <td class="p-4 text-center text-slate-400">{row[2]}</td>
              <td class="p-4 text-center font-medium bg-primary-600/20 border-x-2 border-primary-500 text-white">{row[3]}</td>
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr><td></td><td></td><td></td><td class="border-x-2 border-b-2 border-primary-500 rounded-b-xl h-2 bg-primary-600/20"></td></tr>
        </tfoot>
      </table>
    </div>
  </div>
</section>

<!-- ============ SPIS TREŚCI ============ -->
<section id="zawartosc" class="py-20 md:py-28 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    <SectionHeading title="Co dokładnie znajdziesz w książce?" subtitle="208 stron podzielonych na 16 rozdziałów + praktyczne materiały" />

    <!-- CZĘŚĆ I -->
    <div class="mb-10 bg-primary-50/50 rounded-2xl p-8 reveal border border-primary-100">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="bg-primary-700 text-white px-4 py-2 rounded-lg font-bold text-sm uppercase tracking-wider">Część I</span>
        <h3 class="text-2xl font-bold text-slate-900">Fundamenty copywritingu</h3>
        <span class="text-slate-400 text-sm">(Rozdziały 1–4)</span>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">🧠 Psychologia i perswazja</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>✓ 6 zasad perswazji Cialdiniego w praktyce</li>
            <li>✓ <strong class="text-slate-800">Piramida Maslowa w copywritingu</strong></li>
            <li>✓ Język korzyści vs. cechy — z przykładami</li>
            <li>✓ Storytelling sprzedażowy i framework Bohatera</li>
            <li>✓ Persony — jak zdefiniować odbiorcę</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">✍️ Nagłówki i leady</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>✓ <strong class="text-slate-800">Formuła 4U</strong> (Useful, Urgent, Unique, Ultra-specific)</li>
            <li>✓ 12 typów nagłówków, które działają od dekad</li>
            <li>✓ Power words — lista słów wyzwalających emocje</li>
            <li>✓ 8 typów leadów i śliska zjeżdżalnia</li>
            <li>✓ Technika bucket brigades</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- CZĘŚĆ II -->
    <div class="mb-10 bg-primary-50/50 rounded-2xl p-8 reveal border border-primary-100">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="bg-primary-700 text-white px-4 py-2 rounded-lg font-bold text-sm uppercase tracking-wider">Część II</span>
        <h3 class="text-2xl font-bold text-slate-900">Pisanie konkretnych formatów</h3>
        <span class="text-slate-400 text-sm">(Rozdziały 5–10)</span>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">🎯 Landing page i oferty</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>✓ <strong class="text-slate-800">Anatomia landing page</strong> — 12 elementów</li>
            <li>✓ Above the fold — co musi zobaczyć odwiedzający w 5s</li>
            <li>✓ Formuły PAS i AIDA z przykładami</li>
            <li>✓ Social proof i CTA, które klikają</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">📧 E-maile i opisy produktów</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>✓ 7 typów tematów maila podnoszących open rate</li>
            <li>✓ <strong class="text-slate-800">Sekwencje mailowe</strong> — welcome, nurturing, sales</li>
            <li>✓ Framework Cecha → Zaleta → Korzyść</li>
            <li>✓ Karty produktowe e-commerce</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">📱 Social media i blog</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>✓ Facebook, Instagram, LinkedIn — różnice w stylu</li>
            <li>✓ <strong class="text-slate-800">Artykuły blogowe</strong> — struktura, hooki, skanowalność</li>
            <li>✓ Reklamy płatne — copy w 125 znakach</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2">🏢 Copywriting B2B</h4>
          <ul class="space-y-2 text-slate-600 text-sm">
