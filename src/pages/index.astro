    <div class="flex flex-wrap justify-center gap-6 text-sm text-slate-400 mt-10">
      {['Bezpieczna płatność Stripe','BLIK, karta, Google Pay, Apple Pay','Link na email w 30 sekund'].map(item => (
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-accent-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{item}</span>
      ))}
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section id="faq" class="py-20 md:py-28 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <SectionHeading title="Często zadawane pytania" />
    <div class="space-y-3">
      {faqItems.map(item => (
        <details class="bg-slate-50 rounded-xl p-6 group border border-slate-200/50 hover:border-primary-300 transition-colors">
          <summary class="font-semibold text-slate-900 cursor-pointer flex justify-between items-center gap-4">
            <span>{item.q}</span>
            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-4 text-slate-600 leading-relaxed" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ============ TWO ROADS ============ -->
<section class="py-20 md:py-28 px-4 bg-slate-50">
  <div class="container-narrow text-center">
    <h2 class="text-3xl font-bold text-slate-900 mb-8">Masz dwie drogi do wyboru:</h2>
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="bg-white rounded-2xl p-8 border border-slate-200">
        <h3 class="text-xl font-bold text-red-700 mb-4">❌ Droga trudna</h3>
        <p class="text-slate-600">Zbierasz wiedzę z dziesiątek artykułów. Piszesz „na czuja". Tracisz klientów. Nie wiesz, jak wycenić pracę. Unikasz AI. Może za rok — może za dwa — złożysz z tego wiedzę.</p>
      </div>
      <div class="bg-primary-50 rounded-2xl p-8 border-2 border-primary-300">
        <h3 class="text-xl font-bold text-primary-800 mb-4">✅ Droga prosta</h3>
        <p class="text-slate-700">Kupujesz Copywriting 360° za <strong>49 zł</strong>. Masz 208 stron — formuły, techniki, ćwiczenia, checklisty, AI. Piszesz pierwszy tekst z systemem. Klienci widzą różnicę.</p>
      </div>
    </div>
    <BuyButton text="Wybieram prostą drogę — kupuję ebook" size="lg" />
    <p class="text-slate-500 mt-4 text-sm">{ebook.price} zł · PDF · {ebook.pages} stron · {ebook.chapters} rozdziałów · Rozdział o AI · Dostęp natychmiast</p>
  </div>
</section>

</main>
<Footer />

<!-- Loading overlay -->
<div id="loading-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-2xl p-8 text-center shadow-2xl">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary-500 mx-auto mb-4"></div>
    <p class="text-slate-700 font-medium">Przekierowuję do płatności...</p>
  </div>
</div>

<script define:vars={{ API_URL }}>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.buy-button');
    const loadingOverlay = document.getElementById('loading-overlay');
    buttons.forEach((button) => {
      button.addEventListener('click', async () => {
        const productId = button.dataset.productId;
        loadingOverlay.classList.remove('hidden');
        button.disabled = true;
        try {
          const response = await fetch(`${API_URL}/create-checkout`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId }) });
          const data = await response.json();
          if (data.url) { window.location.href = data.url; } else { throw new Error(data.error || 'Błąd'); }
        } catch (error) {
          console.error('Checkout error:', error);
          loadingOverlay.classList.add('hidden');
          button.disabled = false;
          alert('Wystąpił błąd. Spróbuj ponownie.');
        }
      });
    });
  });
</script>
</Layout>
